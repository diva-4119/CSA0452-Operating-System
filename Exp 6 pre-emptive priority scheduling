#include <stdio.h>

int main() {
    int n, i, time = 0, completed = 0;
    
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt[n], rt[n], pr[n], wt[n], tat[n], p[n];
    int ct[n], visited[n];

    // Input
    for(i = 0; i < n; i++) {
        p[i] = i + 1;
        printf("Enter BT and Priority for P%d: ", i+1);
        scanf("%d %d", &bt[i], &pr[i]);
        rt[i] = bt[i];     // remaining time
        visited[i] = 0;
    }

    // Scheduling
    while(completed < n) {
        int idx = -1;
        int max_pr = -1;

        // Find process with highest priority
        for(i = 0; i < n; i++) {
            if(rt[i] > 0 && pr[i] > max_pr) {
                max_pr = pr[i];
                idx = i;
            }
        }

        // Execute process for 1 unit time
        rt[idx]--;
        time++;

        // If process completes
        if(rt[idx] == 0) {
            completed++;
            ct[idx] = time;  // completion time
        }
    }

    float avg_wt = 0, avg_tat = 0;

    // Calculate WT and TAT
    for(i = 0; i < n; i++) {
        tat[i] = ct[i];        // since arrival time = 0
        wt[i] = tat[i] - bt[i];

        avg_wt += wt[i];
        avg_tat += tat[i];
    }

    printf("\nProcess\tBT\tPR\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\n", p[i], bt[i], pr[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt / n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat / n);

    return 0;
}
