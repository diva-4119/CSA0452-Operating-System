#include <stdio.h>

int main() {
    int n, i, j;
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt[n], pr[n], wt[n], tat[n], p[n];

    // Assign process IDs
    for(i = 0; i < n; i++) {
        p[i] = i + 1;
    }

    // Input
    for(i = 0; i < n; i++) {
        printf("BT and Priority of P%d: ", i+1);
        scanf("%d %d", &bt[i], &pr[i]);
    }

    // Sorting (Higher number = Higher priority)
    for(i = 0; i < n; i++) {
        for(j = i+1; j < n; j++) {
            if(pr[i] < pr[j]) {
                int temp;

                // Swap priority
                temp = pr[i]; pr[i] = pr[j]; pr[j] = temp;

                // Swap burst time
                temp = bt[i]; bt[i] = bt[j]; bt[j] = temp;

                // Swap process ID
                temp = p[i]; p[i] = p[j]; p[j] = temp;
            }
        }
    }

    wt[0] = 0;

    // Waiting Time
    for(i = 1; i < n; i++) {
        wt[i] = wt[i-1] + bt[i-1];
    }

    // Turnaround Time + Average
    for(i = 0; i < n; i++) {
        tat[i] = wt[i] + bt[i];

        avg_wt += wt[i];
        avg_tat += tat[i];
    }

    printf("\nProcess\tBT\tPR\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\n", p[i], bt[i], pr[i], wt[i], tat[i]);
    }

    avg_wt /= n;
    avg_tat /= n;

    printf("\nAverage Waiting Time = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat);

    return 0;
}
